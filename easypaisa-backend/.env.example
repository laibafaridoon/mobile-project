# Server Port Config
PORT=5000

# Easypaisa Merchant Store Credentials
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_integrity_salt_or_hash_key

# Webhook Callback IPN URL (Must be publicly accessible in production)
CALLBACK_URL=https://yourdomain.com/api/payment/callback

# Sandbox or Production URLs
EASYPAISA_INITIATE_URL=https://easypay.easypaisa.com.pk/easypay-service/rest/v4/initiate-transaction
EASYPAISA_VERIFY_URL=https://easypay.easypaisa.com.pk/easypay-service/rest/v4/confirm-transaction

# Simulate Sandbox locally (does not make network calls to Easypaisa)
MOCK_EASYPAISA=true
